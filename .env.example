# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
# Set to: development, staging, production
NODE_ENV=production

# Server port - Render will set this via PORT environment variable
PORT=5000

# API Base URLs - Must match frontend CORS
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
BETTER_AUTH_URL=http://localhost:5000

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# For Render: Use Render's internal PostgreSQL or external database
# Connection string format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@host:port/careerbangla_prod?sslmode=require

# ============================================
# AUTHENTICATION (Better Auth)
# ============================================
# Generate a secure secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your_secure_better_auth_secret_min_32_chars

# Session token expiration
BETTER_AUTH_SESSION_TOKEN_EXPIRES_IN=7d
BETTER_AUTH_SESSION_TOKEN_UPDATE_AGE=1d

# ============================================
# JWT TOKENS (For additional JWT auth if needed)
# ============================================
# Generate secrets: openssl rand -base64 32
ACCESS_TOKEN_SECRET=your_secure_access_token_secret_min_32_chars
REFRESH_TOKEN_SECRET=your_secure_refresh_token_secret_min_32_chars

# Token expiration
ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================
# GOOGLE OAUTH (OAuth 2.0 Login)
# ============================================
# Get credentials from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/callback/google

# ============================================
# EMAIL SERVICE (SMTP)
# ============================================
# Use Gmail, SendGrid, or other SMTP provider
EMAIL_SENDER_SMTP_USER=your_email@gmail.com
EMAIL_SENDER_SMTP_PASS=your_app_specific_password
EMAIL_SENDER_SMTP_HOST=smtp.gmail.com
EMAIL_SENDER_SMTP_PORT=465
EMAIL_SENDER_SMTP_FROM=noreply@your-domain.com

# ============================================
# FILE UPLOAD (Cloudinary)
# ============================================
# Get credentials from: https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# PAYMENT GATEWAY (SSLCommerz)
# ============================================
# Get credentials from: https://developer.sslcommerz.com/
# Set SSL_IS_LIVE=true for production, false for sandbox
SSL_STORE_ID=your_store_id
SSL_STORE_PASSWORD=your_store_password
SSL_IS_LIVE=true

# ============================================
# SEED DATA (Initial Admin Accounts)
# ============================================
# ⚠️  CRITICAL: Change these in production!
# These are used to create default admin accounts on first run
SUPER_ADMIN_EMAIL=superadmin@careerbangla.com
SUPER_ADMIN_PASSWORD=ChangeMe@SuperAdmin123



ADMIN_EMAIL=admin@careerbangla.com
ADMIN_PASSWORD=ChangeMe@Admin123

# ============================================
# PRODUCTION ONLY SETTINGS
# ============================================
# Enable detailed logging in production (use false to reduce logs)
LOG_LEVEL=info

# Maximum file upload size (2MB)
UPLOAD_SIZE_LIMIT=2MB

