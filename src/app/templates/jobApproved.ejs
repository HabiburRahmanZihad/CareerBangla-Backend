<!doctype html>
<html>

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Job Approved</title>
</head>

<body style="margin:0;padding:0;background:#f6f8fb;font-family:Arial,sans-serif;color:#111827;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0"
        style="background:#f6f8fb;padding:24px 12px;">
        <tr>
            <td align="center">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0"
                    style="max-width:640px;background:#ffffff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;">
                    <tr>
                        <td style="padding:20px 24px;background:#0f172a;color:#ffffff;">
                            <h1 style="margin:0;font-size:20px;line-height:1.3;">Job Post Approved</h1>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:24px;">
                            <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hello <strong>
                                    <%= recruiterName %>
                                </strong>,</p>
                            <p style="margin:0 0 16px;font-size:14px;line-height:1.6;">
                                Great news. Your job post has been approved and is now live.
                            </p>

                            <table role="presentation" width="100%" cellspacing="0" cellpadding="0"
                                style="border-collapse:collapse;margin-bottom:16px;">
                                <tr>
                                    <td style="padding:8px 0;font-size:13px;color:#6b7280;width:150px;">Job Title</td>
                                    <td style="padding:8px 0;font-size:13px;color:#111827;"><strong>
                                            <%= jobTitle %>
                                        </strong></td>
                                </tr>
                                <tr>
                                    <td style="padding:8px 0;font-size:13px;color:#6b7280;">Company</td>
                                    <td style="padding:8px 0;font-size:13px;color:#111827;">
                                        <%= companyName %>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:8px 0;font-size:13px;color:#6b7280;">Location</td>
                                    <td style="padding:8px 0;font-size:13px;color:#111827;">
                                        <%= location %>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:8px 0;font-size:13px;color:#6b7280;">Category</td>
                                    <td style="padding:8px 0;font-size:13px;color:#111827;">
                                        <%= category %>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
                                You can now receive applications and manage candidates from your recruiter dashboard.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>

</html>