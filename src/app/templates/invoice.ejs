<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        body { font-family: Arial, sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background: #7c3aed; color: white; padding: 24px; border-radius: 8px 8px 0 0; }
        .header h1 { margin: 0; font-size: 22px; }
        .header p { margin: 5px 0 0; opacity: 0.9; font-size: 14px; }
        .content { background: #f9fafb; padding: 24px; border: 1px solid #e5e7eb; }
        .row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #e5e7eb; }
        .row:last-child { border-bottom: none; }
        .label { color: #6b7280; font-size: 14px; }
        .value { font-weight: 600; font-size: 14px; }
        .total-row { background: #f3f4f6; padding: 12px; border-radius: 6px; margin-top: 16px; }
        .total-label { font-size: 16px; font-weight: 700; }
        .total-value { font-size: 18px; font-weight: 700; color: #7c3aed; }
        .discount { color: #16a34a; }
        .footer { text-align: center; padding: 20px; color: #9ca3af; font-size: 12px; }
        .badge { display: inline-block; background: #16a34a; color: white; padding: 4px 12px; border-radius: 4px; font-size: 12px; font-weight: 600; }
        table { width: 100%; border-collapse: collapse; }
        td { padding: 8px 0; }
        .td-label { color: #6b7280; font-size: 14px; }
        .td-value { font-weight: 600; font-size: 14px; text-align: right; }
    </style>
</head>
<body>
    <div class="header">
        <h1>CareerBangla</h1>
        <p>Subscription Invoice</p>
    </div>
    <div class="content">
        <p>Hello <strong><%= name %></strong>,</p>
        <p>Thank you for your purchase! Your premium subscription has been activated. Here are your invoice details:</p>

        <table>
            <tr>
                <td class="td-label">Plan</td>
                <td class="td-value"><%= plan %> Premium</td>
            </tr>
            <tr>
                <td class="td-label">Transaction ID</td>
                <td class="td-value"><%= transactionId %></td>
            </tr>
            <tr>
                <td class="td-label">Subscription Period</td>
                <td class="td-value"><%= periodStart %> &mdash; <%= periodEnd %></td>
            </tr>
            <tr>
                <td class="td-label">Original Amount</td>
                <td class="td-value">BDT <%= originalAmount %></td>
            </tr>
            <% if (discount > 0) { %>
            <tr>
                <td class="td-label">Discount<% if (couponCode) { %> (<%= couponCode %>)<% } %></td>
                <td class="td-value discount">-BDT <%= discount %></td>
            </tr>
            <% } %>
        </table>

        <div class="total-row">
            <table>
                <tr>
                    <td class="total-label">Total Paid</td>
                    <td class="total-value" style="text-align: right;">BDT <%= amount %></td>
                </tr>
            </table>
        </div>

        <p style="margin-top: 16px;">Status: <span class="badge">PAID</span></p>
        <p style="font-size: 13px; color: #6b7280;">Your invoice PDF is attached to this email. You can also download it from your dashboard.</p>
    </div>
    <div class="footer">
        <p>CareerBangla - Your Career Partner</p>
        <p>This is an automated email. Please do not reply.</p>
    </div>
</body>
</html>
