model User {
  id                       String                    @id
  name                     String
  email                    String                    @unique
  emailVerified            Boolean                   @default(false)
  role                     Role                      @default(USER)
  status                   UserStatus                @default(ACTIVE)
  needPasswordChange       Boolean                   @default(false)
  isDeleted                Boolean                   @default(false)
  deletedAt                DateTime?
  image                    String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  isPremium                Boolean                   @default(false)
  premiumUntil             DateTime?
  referralCode             String?                   @unique
  referredBy               String?
  phone                    String?                   @unique
  country                  String?
  accounts                 Account[]
  admin                    Admin?
  applications             Application[]
  candidateDownloads       CvDownload[]              @relation("candidateDownloads")
  recruitedDownloads       CvDownload[]              @relation("recruitedDownloads")
  notifications            Notification[]
  recruiter                Recruiter?
  referralsReceived        ReferralHistory?          @relation("ReferredUser")
  referralsMade            ReferralHistory[]         @relation("ReferredBy")
  resume                   Resume?
  sessions                 Session[]
  subscriptions            Subscription[]
  subscriptionReminderLogs SubscriptionReminderLog[]

  @@index([role])
  @@index([status])
  @@index([isDeleted])
  @@index([referredBy])
  @@index([isPremium])
  @@index([createdAt])
  @@map("user")
}

model Session {
  id                    String    @id
  expiresAt             DateTime
  token                 String    @unique
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  ipAddress             String?
  userAgent             String?
  userId                String
  accessToken           String?
  accessTokenExpiresAt  DateTime?
  refreshToken          String?
  refreshTokenExpiresAt DateTime?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model ReferralHistory {
  id             String    @id @default(uuid(7))
  referrerId     String
  referredUserId String    @unique
  hasPaid        Boolean   @default(false)
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  referredUser   User      @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  referrer       User      @relation("ReferredBy", fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([referrerId, hasPaid])
  @@map("referral_history")
}
