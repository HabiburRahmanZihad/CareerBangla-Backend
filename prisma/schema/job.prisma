model Job {
  id               String        @id @default(uuid(7))
  title            String
  description      String
  requirements     String[]
  responsibilities String[]
  location         String
  jobType          JobType       @default(FULL_TIME)
  salaryMin        Float?
  salaryMax        Float?
  experience       String?
  education        String?
  skills           String[]
  benefits         String[]
  deadline         DateTime
  vacancies        Int           @default(1)
  featuredJob      Boolean       @default(false)
  urgentHiring     Boolean       @default(false)
  allowVideoCv     Boolean       @default(false)
  tags             String[]
  status           JobStatus     @default(PENDING)
  isDeleted        Boolean       @default(false)
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  recruiterId      String
  categoryId       String?
  applications     Application[]
  category         JobCategory?  @relation(fields: [categoryId], references: [id])
  recruiter        Recruiter     @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  @@index([recruiterId], map: "idx_job_recruiterId")
  @@index([status], map: "idx_job_status")
  @@index([isDeleted], map: "idx_job_isDeleted")
  @@index([jobType], map: "idx_job_jobType")
  @@index([categoryId], map: "idx_job_categoryId")
  @@index([createdAt], map: "idx_job_createdAt")
  @@index([isDeleted, status], map: "idx_job_active")
  @@index([recruiterId, isDeleted], map: "idx_job_recruiter_active")
  @@map("job")
}

model JobCategory {
  id        String   @id @default(uuid(7))
  title     String   @unique
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]

  @@map("job_category")
}
