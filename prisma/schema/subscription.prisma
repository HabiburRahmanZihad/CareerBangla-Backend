model Subscription {
  id                 String           @id @default(uuid(7))
  plan               SubscriptionPlan @default(FREE)
  amount             Float            @default(0)
  transactionId      String?          @unique
  val_id             String?          @unique // SSLCommerz validation ID
  bank_tran_id       String?
  store_amount       Float?
  card_type          String?
  status             PaymentStatus    @default(UNPAID)
  paymentGatewayData Json?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  couponId   String?
  referralId String?

  // Indicates if this subscription is for a recruiter (vs user)
  isRecruiterSubscription Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reminderLogs SubscriptionReminderLog[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([createdAt])
  @@index([isRecruiterSubscription])
  @@map("subscription")
}
