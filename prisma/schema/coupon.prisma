model Coupon {
  id         String       @id @default(uuid(7))
  code       String       @unique
  coins      Int
  status     CouponStatus @default(ACTIVE)
  usedBy     String?
  usedAt     DateTime?
  expiresAt  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([code])
  @@index([status])
  @@map("coupon")
}

model GiftVoucher {
  id           String       @id @default(uuid(7))
  code         String       @unique
  coins        Int
  status       CouponStatus @default(ACTIVE)
  recipientEmail String?
  usedBy       String?
  usedAt       DateTime?
  expiresAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([code])
  @@index([status])
  @@map("gift_voucher")
}
