model Coupon {
  id                String          @id @default(uuid(7))
  code              String          @unique
  type              CouponType
  targetRole        CouponTargetRole @default(USER)
  description       String?

  // Discount fields (PERCENT_DISCOUNT, AMOUNT_DISCOUNT, REFERRAL)
  discountPercent   Float?
  discountAmount    Float?

  // Subscription fields (FREE_DAYS, RECRUITER_DAYS)
  freeDays          Int?
  // Subscription fields (RECRUITER_MONTHS)
  freeMonths        Int?
  // Lifetime flag (LIFETIME_FREE)
  isLifetime        Boolean         @default(false)

  // Referral coupon: recruiter earns commission per user redemption
  commissionAmount  Float?
  linkedRecruiterId String?         // Recruiter.id (plain ref, no formal relation)

  maxUsage          Int             @default(1)
  usageCount        Int             @default(0)

  status            CouponStatus    @default(ACTIVE)
  expiresAt         DateTime?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  usages            CouponUsage[]

  @@index([code])
  @@index([status])
  @@index([type])
  @@map("coupon")
}

model CouponUsage {
  id        String   @id @default(uuid(7))
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  usedAt    DateTime @default(now())

  @@unique([couponId, userId])
  @@index([couponId])
  @@index([userId])
  @@map("coupon_usage")
}
