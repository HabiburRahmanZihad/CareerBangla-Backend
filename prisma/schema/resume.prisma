model Resume {
  id                    String           @id @default(uuid(7))
  skills                String[]
  experience            Json[]
  linkedinUrl           String?
  portfolioUrl          String?
  gender                Gender?
  dateOfBirth           DateTime?
  contactNumber         String?
  address               String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  userId                String           @unique
  profileCompletedAt    DateTime?
  email                 String?
  fullName              String?
  githubUrl             String?
  interests             String[]
  nationality           String?
  professionalSummary   String?
  professionalTitle     String?
  profilePhoto          String?
  softSkills            String[]
  technicalSkills       String[]
  toolsAndTechnologies  String[]
  websiteUrl            String?
  certifications_legacy Json[]
  awards                Award[]
  certifications        Certification[]
  education             Education[]
  languages             Language[]
  projects              Project[]
  references            Reference[]
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workExperience        WorkExperience[]

  @@map("resume")
}

model WorkExperience {
  id               String    @id @default(uuid(7))
  jobTitle         String
  companyName      String
  employmentType   String?
  location         String?
  startDate        DateTime
  endDate          DateTime?
  currentlyWorking Boolean   @default(false)
  responsibilities String[]
  achievements     String[]
  technologiesUsed String[]
  resumeId         String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  resume           Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("work_experience")
}

model Education {
  id                String    @id @default(uuid(7))
  degree            String
  fieldOfStudy      String
  institutionName   String
  location          String?
  startDate         DateTime
  endDate           DateTime?
  currentlyStudying Boolean   @default(false)
  cgpaOrResult      String?
  description       String?
  resumeId          String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  resume            Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("education")
}

model Certification {
  id                  String    @id @default(uuid(7))
  certificationName   String
  issuingOrganization String
  issueDate           DateTime
  expiryDate          DateTime?
  credentialId        String?
  credentialUrl       String?
  resumeId            String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  resume              Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("certification")
}

model Project {
  id               String    @id @default(uuid(7))
  projectName      String
  role             String?
  description      String
  technologiesUsed String[]
  liveUrl          String?
  githubUrl        String?
  startDate        DateTime?
  endDate          DateTime?
  highlights       String[]
  resumeId         String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  resume           Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("project")
}

model Language {
  id               String   @id @default(uuid(7))
  language         String
  proficiencyLevel String
  resumeId         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  resume           Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("language")
}

model Award {
  id          String   @id @default(uuid(7))
  title       String
  issuer      String
  date        DateTime
  description String?
  resumeId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resume      Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("award")
}

model Reference {
  id           String   @id @default(uuid(7))
  name         String
  designation  String?
  company      String?
  email        String?
  phone        String?
  relationship String?
  resumeId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("reference")
}
